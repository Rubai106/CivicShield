NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database — format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Default local values: user=postgres, host=localhost, port=5432, dbname=civicshield
DATABASE_URL=postgresql://postgres:<your_postgres_password>@localhost:5432/civicshield
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
